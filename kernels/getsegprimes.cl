	(ushort2)(65033u, 10968u), (ushort2)(65053u, 47118u), (ushort2)(65063u, 30275u), (ushort2)(65071u, 4311u),
	(ushort2)(65089u, 14479u), (ushort2)(65099u, 24346u), (ushort2)(65101u, 9017u), (ushort2)(65111u, 2647u),
	(ushort2)(65119u, 46150u), (ushort2)(65123u, 58072u), (ushort2)(65129u, 50479u), (ushort2)(65141u, 32659u),
	(ushort2)(65147u, 63041u), (ushort2)(65167u, 41246u), (ushort2)(65171u, 35777u), (ushort2)(65173u, 527u),
	(ushort2)(65179u, 5813u), (ushort2)(65183u, 42130u), (ushort2)(65203u, 64938u), (ushort2)(65213u, 54647u),
	(ushort2)(65239u, 7010u), (ushort2)(65257u, 14955u), (ushort2)(65267u, 62988u), (ushort2)(65269u, 23264u),
	(ushort2)(65287u, 43199u), (ushort2)(65293u, 1305u), (ushort2)(65309u, 35598u), (ushort2)(65323u, 33499u),
	(ushort2)(65327u, 34799u), (ushort2)(65353u, 28554u), (ushort2)(65357u, 1779u), (ushort2)(65371u, 42739u),
	(ushort2)(65381u, 57020u), (ushort2)(65393u, 43321u), (ushort2)(65407u, 2770u), (ushort2)(65413u, 44486u),
	(ushort2)(65419u, 32055u), (ushort2)(65423u, 3374u), (ushort2)(65437u, 63129u), (ushort2)(65447u, 34685u),
	(ushort2)(65449u, 45593u), (ushort2)(65479u, 2612u), (ushort2)(65497u, 55857u), (ushort2)(65519u, 12867u),
	(ushort2)(65521u, 12227u)
};

/*
	bitmap bit j represents P + 2*j.

	This table is indexed by an odd residue r as r >> 1, where
	r = 1, 3, 5, ..., 209.

	A set bit marks a number divisible by 3, 5, or 7.
	A uint word covers 32 odd numbers, so the residues in one word are:
		r, r+2, r+4, ..., r+62  (mod 210)
*/
__constant uint wheel210_357_mask[105] = {
	0x9B4B349Eu, 0xCDA59A4Fu, 0x66D2CD27u, 0xB3696693u, 0x59B4B349u,
	0x2CDA59A4u, 0x966D2CD2u, 0xCB369669u, 0x659B4B34u, 0xB2CDA59Au,
	0x5966D2CDu, 0xACB36966u, 0xD659B4B3u, 0x6B2CDA59u, 0xB5966D2Cu,
	0xDACB3696u, 0xED659B4Bu, 0x76B2CDA5u, 0xBB5966D2u, 0x5DACB369u,
	0x2ED659B4u, 0x976B2CDAu, 0x4BB5966Du, 0x25DACB36u, 0x92ED659Bu,
	0x4976B2CDu, 0xA4BB5966u, 0xD25DACB3u, 0xE92ED659u, 0x74976B2Cu,
	0xBA4BB596u, 0xDD25DACBu, 0x6E92ED65u, 0xB74976B2u, 0x5BA4BB59u,
	0xADD25DACu, 0xD6E92ED6u, 0x6B74976Bu, 0x35BA4BB5u, 0x9ADD25DAu,
	0x4D6E92EDu, 0xA6B74976u, 0xD35BA4BBu, 0x69ADD25Du, 0x34D6E92Eu,
	0x9A6B7497u, 0xCD35BA4Bu, 0x669ADD25u, 0xB34D6E92u, 0xD9A6B749u,
	0x6CD35BA4u, 0xB669ADD2u, 0x5B34D6E9u, 0x2D9A6B74u, 0x96CD35BAu,
	0x4B669ADDu, 0xA5B34D6Eu, 0xD2D9A6B7u, 0x696CD35Bu, 0x34B669ADu,
	0x9A5B34D6u, 0xCD2D9A6Bu, 0x6696CD35u, 0xB34B669Au, 0x59A5B34Du,
	0x2CD2D9A6u, 0x96696CD3u, 0x4B34B669u, 0x259A5B34u, 0x92CD2D9Au,
	0xC96696CDu, 0xE4B34B66u, 0xF259A5B3u, 0x792CD2D9u, 0x3C96696Cu,
	0x9E4B34B6u, 0xCF259A5Bu, 0xE792CD2Du, 0xF3C96696u, 0x79E4B34Bu,
	0x3CF259A5u, 0x9E792CD2u, 0x4F3C9669u, 0x279E4B34u, 0x93CF259Au,
	0x49E792CDu, 0xA4F3C966u, 0xD279E4B3u, 0x693CF259u, 0x349E792Cu,
	0x9A4F3C96u, 0xCD279E4Bu, 0x6693CF25u, 0xB349E792u, 0x59A4F3C9u,
	0x2CD279E4u, 0x96693CF2u, 0x4B349E79u, 0xA59A4F3Cu, 0xD2CD279Eu,
	0x696693CFu, 0xB4B349E7u, 0xDA59A4F3u, 0x6D2CD279u, 0x3696693Cu
};

static inline uint wheel210_word_mask(uint pmod210, uint word_index)
{
	/*
		One bitmap word advances by 32 odd numbers.
		That is +64 in the number line.

		Period in words:
			210 / gcd(210, 64) = 105
	*/
	uint r = pmod210 + 64u * (word_index % 105u);
	r %= 210u;

	return wheel210_357_mask[r >> 1];
}

static inline uint ctz32(uint x)
{
	// x must be nonzero
	uint lsb = x & (0u - x);
	return 31u - clz(lsb);
}

#define MASK24 0x00FFFFFFu
#define BITMAP_BITS (BITMAP_WORDS * 32)
#define BITMAP_RANGE (BITMAP_BITS * 2)

__kernel void getsegprimes(const cl_uint96_t low, const cl_uint96_t high, __global uint *g_primecount, __global cl_uint96_t *g_prime){

	uint gid = get_global_id(0);
	int group = get_group_id(0);
	int lid = get_local_id(0);
	int ls = get_local_size(0);
	__local uint bitmap[BITMAP_WORDS];
	__local cl_uint96_t P;
	__local ulong lo56,hi40;
	__local uint pmod210,overflow;

	// low must be odd
	if(!lid){
		uint of;
		P = add_u32_carry(low, group * BITMAP_RANGE, &of);
		overflow = of;
		lo56 = (ulong)P.lo | (((ulong)(P.mid & MASK24)) << 32);
		hi40 = (P.mid >> 24) | (((ulong)P.hi) << 8);
		/*
			P = hi40 * 2^56 + lo56
			2^56 mod 210 = 46
		*/
		pmod210 = (uint)((lo56 + hi40*46) % 210);
	}
	barrier(CLK_LOCAL_MEM_FENCE);

	if(overflow) return;

	/*
		Initialize as already sieved by 3, 5, and 7.
		Bits set to 1 are composite/non-candidate.
	*/
	for(int i=lid; i<BITMAP_WORDS; i+=ls){
		bitmap[i] = wheel210_word_mask(pmod210, i);
	}
	barrier(CLK_LOCAL_MEM_FENCE);

	for(int i = lid; i < SMALL_PRIME_COUNT; i += ls){
		ushort2 rp = prime_pow2_56_mod[i];
		uint sp = (uint)rp.s0;
		uint mp = (uint)rp.s1;
		uint lowmodp = (lo56 + hi40*mp) % sp;
		/*
			Find first bitmap bit j where:
			P + 2*j == 0 mod p
		*/
		uint neg_lowmodp = (lowmodp == 0) ? 0 : (sp - lowmodp);
		/*
			bit = neg_lowmodp / 2 mod sp

			If neg_lowmodp is even:
			bit = neg_lowmodp / 2

			If neg_lowmodp is odd:
			bit = (neg_lowmodp + sp) / 2
		*/
		uint bit = (neg_lowmodp + ((neg_lowmodp & 1u) ? sp : 0u)) >> 1;

		/*
			For small ranges, do not mark sp itself.
			Start crossing off sp at sp*sp instead.
			This keeps primes such as 11 and 13 in the bitmap,
			but still removes composites such as 121, 143, 169, etc.
		*/
		if(!hi40){
			uint sp2 = (uint)sp * (uint)sp;
			if(sp2 >= lo56){
				uint bit_sp2 = (uint)((sp2 - lo56) >> 1);
				if(bit < bit_sp2){
					uint delta = bit_sp2 - bit;
					uint steps = (delta + sp - 1u) / sp;
					bit += steps * sp;
				}
			}
		}

		if(bit < BITMAP_BITS){
			uint cur_word = bit >> 5;
			uint word_mask = 0;
			for(; bit < BITMAP_BITS; bit += sp){
				uint word = bit >> 5;
				uint mask = 1u << (bit & 31u);
				if(word != cur_word){
					atomic_or(&bitmap[cur_word], word_mask);
					cur_word = word;
					word_mask = mask;
				}
				else{
					word_mask |= mask;
				}
			}
			atomic_or(&bitmap[cur_word], word_mask);
		}
	}

	barrier(CLK_LOCAL_MEM_FENCE);

	for(int i = lid; i < BITMAP_WORDS; i += ls){
		uint word = ~bitmap[i];
		while(word){
			uint b = ctz32(word);
			word &= word - 1u;	// clear bit
			uint bit_index = i * 32u + b;	// global bit index in the number line
			// candidate = segment_low + 2 * bit_index
			uint offset = bit_index << 1;
			uint of;
			cl_uint96_t N = add_u32_carry(P, offset, &of);
			if( !of && lt96(N, high) ){
				uint j = atomic_inc(&g_primecount[0]);
				g_prime[j] = N;
			}
		}
	}
}














